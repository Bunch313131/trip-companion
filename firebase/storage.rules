rules_version = '2';

// Storage bucket rules — trip-scoped reservation documents.
// Path pattern: reservations/{tripId}/{reservationId}/{filename}
//
// NOTE: cross-service firestore.get() (to check trip membership) does not
// evaluate reliably on this project's .firebasestorage.app bucket, so we gate
// on authentication + file type/size instead. This is a sound boundary for a
// private app: tripIds are non-guessable content hashes, and all trip data in
// Firestore stays members-only — so a signed-in non-member can't discover a
// tripId or read reservation metadata to target a file.

service firebase.storage {
  match /b/{bucket}/o {
    match /reservations/{tripId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if request.auth != null;
    }
  }
}
